<Window x:Class="MultiClod.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MultiClod.App"
        xmlns:skills="clr-namespace:MultiClod.App.Skills"
        xmlns:settings="clr-namespace:MultiClod.App.Settings"
        xmlns:costs="clr-namespace:MultiClod.App.Costs"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Multi-Clod" Height="600" Width="1000"
        KeyboardNavigation.DirectionalNavigation="None"
        KeyboardNavigation.TabNavigation="None">
    <!--
        DirectionalNavigation/TabNavigation="None" on the Window is required, not just on
        WpfTerminalPane's own internal container: without it, pressing an arrow key while the
        hosted native terminal has focus makes WPF's navigation system move focus up to an
        ancestor control instead of the terminal's native hwnd, and every subsequent keystroke
        then silently goes nowhere.
    -->
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type local:ProjectNodeViewModel}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" Margin="2"
                       TextTrimming="CharacterEllipsis" />
        </HierarchicalDataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type local:SessionNodeViewModel}" ItemsSource="{Binding Children}">
            <!--
                A Grid, not a StackPanel: the name column below is "*" so it actually shrinks as
                the tree panel narrows, which is what lets SessionNameText's TextTrimming kick in.
                A horizontal StackPanel measures children at infinite width, so a TextBlock inside
                one never trims - it just grows past the row's bounds. See the TreeViewItem
                ControlTemplate's own column swap (name "*" / cost Auto) below for the other half
                of this fix.
            -->
            <Grid Margin="2" ToolTip="{Binding ToolTipText}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                    <!-- IsHollow (NotStarted/Exited/Dormant) swaps Fill for Transparent below, leaving just the Stroke outline. -->
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{Binding StatusBrush}"
                             Stroke="{Binding StatusBrush}" StrokeThickness="1.5" />
                    <!-- Rotating dashed ring stands in for the dot while the session is Starting - see the IsStarting trigger below. -->
                    <Ellipse x:Name="StatusSpinner" Width="10" Height="10" Visibility="Collapsed"
                             Stroke="Goldenrod" StrokeThickness="1.5" StrokeDashArray="2 1.5"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="StatusSpinnerRotate" Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <!-- Solid (non-dashed) ring in violet signals Claude actively working on a
                         turn - distinct in both color and dash pattern from the goldenrod dashed
                         IsStarting spinner above. See the Activity==Working trigger below. -->
                    <Ellipse x:Name="WorkingSpinner" Width="10" Height="10" Visibility="Collapsed"
                             Stroke="MediumPurple" StrokeThickness="1.5" StrokeDashArray="3 1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="WorkingSpinnerRotate" Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <!-- Latches until the user re-selects this session - see
                         SessionNodeViewModel.ClearLatchedActivity. -->
                    <Grid x:Name="NeedsInputGlyph" Visibility="Collapsed">
                        <Ellipse Width="10" Height="10" Fill="Orange" />
                        <TextBlock Text="?" FontSize="8" FontWeight="Bold" Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                    </Grid>
                    <Grid x:Name="DoneGlyph" Visibility="Collapsed">
                        <Ellipse Width="10" Height="10" Fill="Teal" />
                        <TextBlock Text="&#10003;" FontSize="7" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                    </Grid>
                </Grid>
                <TextBlock x:Name="SessionNameText" Grid.Column="1" Text="{Binding Name}"
                           Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsInvalid}" Value="True">
                    <Setter TargetName="SessionNameText" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="SessionNameText" Property="Foreground" Value="{DynamicResource Theme.Brush.SecondaryForeground}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsHollow}" Value="True">
                    <Setter TargetName="StatusDot" Property="Fill" Value="Transparent" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsStarting}" Value="True">
                    <Setter TargetName="StatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="StatusSpinner" Property="Visibility" Value="Visible" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="SpinnerStoryboard">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="StatusSpinnerRotate" Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinnerStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding Activity}" Value="{x:Static local:SessionActivity.Working}">
                    <Setter TargetName="StatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="WorkingSpinner" Property="Visibility" Value="Visible" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="WorkingSpinnerStoryboard">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="WorkingSpinnerRotate" Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:1.2" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="WorkingSpinnerStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding Activity}" Value="{x:Static local:SessionActivity.NeedsInput}">
                    <Setter TargetName="StatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="NeedsInputGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Activity}" Value="{x:Static local:SessionActivity.Done}">
                    <Setter TargetName="StatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="DoneGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!--
            Drag/drop is wired on every TreeViewItem via this shared style, AND separately on the
            Tree element itself in the TreeView tag below (see OnTreeDragOver/OnTreeDrop) - a
            TreeView's rows don't fill its whole bounds, so a drop below the last item routes to
            the TreeView, not any TreeViewItem. Because DragOver/Drop are bubbling routed events, a
            drop that lands on an actual row is handled by that row's own handler first, which
            marks e.Handled = true so the Tree-level handler only ever fires for genuine
            empty-area drops - no manual hit-testing needed to tell the two cases apart.

            IsSelected/IsExpanded are TwoWay so code (e.g. MainWindow.HandleFromHereRequest) can
            select/expand a node by setting the view model, and WPF applies it whenever that
            node's container materializes - no polling ItemContainerGenerator for a container that
            may not exist yet.
        -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <EventSetter Event="Selected" Handler="OnItemSelected" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnItemPreviewMouseLeftButtonDown" />
            <EventSetter Event="PreviewMouseMove" Handler="OnItemPreviewMouseMove" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="DragOver" Handler="OnItemDragOver" />
            <EventSetter Event="Drop" Handler="OnItemDrop" />
            <!--
                Full retemplate rather than a resource-key override: the default (Aero2) template
                pulls its expand/collapse glyph style via a StaticResource lookup that's resolved
                inside the theme's own dictionary, so an app-level resource of the same key is
                never seen. Re-declaring the whole template is the only way to force the glyph's
                color - this copies the stock Aero2 layout/selection triggers verbatim and only
                replaces the ToggleButton's glyph style with a fixed LimeGreen triangle (matching
                the running-session status dot color) instead of the stock dark/hover-only colors.
            -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MinWidth="19" Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="Expander" ClickMode="Press"
                                          IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Width" Value="16" />
                                        <Setter Property="Height" Value="16" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent" Height="16" Padding="5" Width="16">
                                                        <Path x:Name="ExpandPath" Data="M0,0L0,6L6,0z"
                                                              Fill="LimeGreen" Stroke="LimeGreen">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="135" CenterX="3" CenterY="3" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="RenderTransform" TargetName="ExpandPath">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="3" CenterY="3" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    Grid.Column="1" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header" ContentSource="Header"
                                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                   SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                            <!--
                                Deliberately a sibling of Bd (the selection-highlighted header
                                border above), not inside it - Column 1 (Bd/name) is "*" so it
                                shrinks as the tree panel narrows (its TextBlock then trims via
                                TextTrimming), while this badge lives in Column 2, which is Auto so
                                it always renders at its full natural size and stays flush against
                                the GridSplitter regardless of how long the name is - a long name
                                trims away rather than pushing the cost off the visible edge. The
                                TreeViewItem's own DataContext is whatever node is bound (project or
                                session), which is why CostBadgeText has a safe always-null default
                                on the shared TreeNodeViewModel base - a project row binds
                                harmlessly.
                            -->
                            <costs:CostBadge Grid.Row="0" Grid.Column="2" CostText="{Binding CostBadgeText}"
                                              BreakdownText="{Binding CostBreakdownText}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter Property="Visibility" TargetName="ItemsHost" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter Property="Visibility" TargetName="Expander" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" TargetName="Bd" Value="{DynamicResource {x:Static sys:SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.HighlightTextBrushKey}}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" TargetName="Bd" Value="{DynamicResource {x:Static sys:SystemColors.ControlBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.ControlTextBrushKey}}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static sys:SystemColors.GrayTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            One tab per open session in the main panel's tab strip (MainWindow.TabStrip) - see
            MainWindow.OpenTab/CloseTab. Mirrors the tree's status-dot glyphs (IsHollow/NeedsInput/
            Done) so a background tab still signals it needs attention without switching to it, but
            skips the tree's animated Starting/Working spinners - not worth the extra visual noise
            at tab-strip size.
        -->
        <DataTemplate x:Key="SessionTabItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="6,3" ToolTip="{Binding ToolTipText}">
                <Grid Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse x:Name="TabStatusDot" Width="8" Height="8" Fill="{Binding StatusBrush}"
                             Stroke="{Binding StatusBrush}" StrokeThickness="1.5" />
                    <Grid x:Name="TabNeedsInputGlyph" Visibility="Collapsed">
                        <Ellipse Width="10" Height="10" Fill="Orange" />
                        <TextBlock Text="?" FontSize="8" FontWeight="Bold" Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                    </Grid>
                    <Grid x:Name="TabDoneGlyph" Visibility="Collapsed">
                        <Ellipse Width="10" Height="10" Fill="Teal" />
                        <TextBlock Text="&#10003;" FontSize="7" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                    </Grid>
                </Grid>
                <TextBlock Text="{Binding DisplayTitle}" Foreground="White" VerticalAlignment="Center"
                           MaxWidth="160" TextTrimming="CharacterEllipsis" />
                <costs:CostBadge CostText="{Binding CostBadgeText}" BreakdownText="{Binding CostBreakdownText}" VerticalAlignment="Center" Margin="6,0,0,0" />
                <Button Content="&#10005;" Width="16" Height="16" Margin="8,0,0,0" Padding="0"
                        Background="Transparent" BorderThickness="0" Foreground="Gray" Cursor="Hand"
                        VerticalAlignment="Center" Click="OnCloseTabClick" ToolTip="Close tab" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsHollow}" Value="True">
                    <Setter TargetName="TabStatusDot" Property="Fill" Value="Transparent" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Activity}" Value="{x:Static local:SessionActivity.NeedsInput}">
                    <Setter TargetName="TabStatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="TabNeedsInputGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Activity}" Value="{x:Static local:SessionActivity.Done}">
                    <Setter TargetName="TabStatusDot" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="TabDoneGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Selected tab gets the same blue accent (bottom edge) as the tree's focused-selection
             highlight, for visual consistency; unselected tabs are flat with a thin divider. -->
        <Style x:Key="SessionTabItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,1,2" />
            <Setter Property="BorderBrush" Value="#2D2D30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A96DD" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252526" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- BorderThickness starts at 0 (invisible) - MainWindow's ctor sets it to a visible red
         border under #if DEBUG, since XAML itself can't be conditionally compiled. -->
    <Border x:Name="DebugBorder" BorderBrush="Red" BorderThickness="0">
    <Grid Background="{DynamicResource Theme.Brush.WindowBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition x:Name="TreeColumn" Width="220" MinWidth="120" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!--
            Rail: icon strip for major features. Each item's accent bar Visibility and the
            corresponding Panel/canvas content are driven from code-behind by
            MainWindow.SetRailSection (see RailSection) - MouseLeftButtonDown on each icon
            Grid calls into it.
        -->
        <Border Grid.Column="0" Background="{DynamicResource Theme.Brush.RailBackground}" BorderBrush="{DynamicResource Theme.Brush.Border}" BorderThickness="0,0,1,0">
            <StackPanel>
                <Grid x:Name="SessionsRailIcon" Width="48" Height="48" Margin="0,8,0,0"
                      MouseLeftButtonDown="OnSessionsRailIconClick">
                    <!-- Accent bar marks this item as the one owning the currently visible Panel. -->
                    <Border x:Name="SessionsAccentBar" Width="3" HorizontalAlignment="Left" Background="{DynamicResource Theme.Brush.Accent}" />
                    <Border Width="32" Height="32" Background="{DynamicResource Theme.Brush.RailTileBackground}" CornerRadius="4">
                        <!-- Single sunburst petal-flower, echoing the coral bursts in Assets/app.png (the app's own icon) at one-third scale. -->
                        <Canvas Width="24" Height="24">
                            <Canvas.Resources>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="3" />
                                    <Setter Property="Height" Value="11" />
                                    <Setter Property="Fill" Value="{DynamicResource Theme.Brush.AccentCoral}" />
                                    <Setter Property="Canvas.Left" Value="10.5" />
                                    <Setter Property="Canvas.Top" Value="1" />
                                </Style>
                            </Canvas.Resources>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="0" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="60" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="120" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="180" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="240" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                            <Ellipse><Ellipse.RenderTransform><RotateTransform Angle="300" CenterX="1.5" CenterY="11" /></Ellipse.RenderTransform></Ellipse>
                        </Canvas>
                    </Border>
                </Grid>

                <Grid x:Name="SkillsRailIcon" Width="48" Height="48"
                      MouseLeftButtonDown="OnSkillsRailIconClick">
                    <Border x:Name="SkillsAccentBar" Width="3" HorizontalAlignment="Left" Background="{DynamicResource Theme.Brush.Accent}" Visibility="Collapsed" />
                    <Border Width="32" Height="32" Background="{DynamicResource Theme.Brush.RailTileBackground}" CornerRadius="4">
                        <!-- Simple document/sheet glyph (rounded card + three ruled lines) for the Skills panel.
                             The card and its ruled lines are a fixed pair (not theme-linked) - the lines are
                             just cutout strokes against the card's own AccentSecondary fill, unrelated to the
                             surrounding window theme. -->
                        <Canvas Width="24" Height="24">
                            <Border Width="16" Height="20" Canvas.Left="4" Canvas.Top="2" CornerRadius="2" Background="{DynamicResource Theme.Brush.AccentSecondary}" />
                            <Rectangle Width="10" Height="1.5" Canvas.Left="7" Canvas.Top="7" Fill="#1E1E1E" />
                            <Rectangle Width="10" Height="1.5" Canvas.Left="7" Canvas.Top="11" Fill="#1E1E1E" />
                            <Rectangle Width="6" Height="1.5" Canvas.Left="7" Canvas.Top="15" Fill="#1E1E1E" />
                        </Canvas>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsRailIcon" Width="48" Height="48"
                      MouseLeftButtonDown="OnSettingsRailIconClick">
                    <Border x:Name="SettingsAccentBar" Width="3" HorizontalAlignment="Left" Background="{DynamicResource Theme.Brush.Accent}" Visibility="Collapsed" />
                    <Border Width="32" Height="32" Background="{DynamicResource Theme.Brush.RailTileBackground}" CornerRadius="4">
                        <!-- Gear glyph from Assets/settings.png, used as an OpacityMask over a plain
                             fill so its alpha shape renders in the rail's icon color instead
                             of the source PNG's own black. -->
                        <Rectangle Width="20" Height="20" Fill="{DynamicResource Theme.Brush.PrimaryForeground}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="/Assets/settings.png" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <TreeView x:Name="Tree" Background="{DynamicResource Theme.Brush.WindowBackground}" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      AllowDrop="True"
                      SelectedItemChanged="OnTreeSelectedItemChanged"
                      KeyDown="OnTreeKeyDown"
                      MouseRightButtonDown="OnTreeMouseRightButtonDown"
                      ContextMenuOpening="OnTreeContextMenuOpening"
                      DragOver="OnTreeDragOver"
                      Drop="OnTreeDrop">
                <TreeView.Resources>
                    <!-- Focused-selected row: echoes the terminal pane's own text-selection accent (ThemeManager's Accent color) for visual consistency. -->
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="{DynamicResource Theme.Color.Accent}" />
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="White" />

                    <!--
                        Unfocused-selected row: Aero2's TreeViewItem template (unlike ListBoxItem) uses
                        ControlBrushKey/ControlTextBrushKey for this state rather than the newer
                        InactiveSelectionHighlight* keys, so both pairs are overridden defensively - an
                        unused pair is a harmless no-op. Without this, an unfocused selected row falls
                        back to plain light gray behind hardcoded white text, which is illegible - and
                        the tree is frequently unfocused since the hosted terminal control constantly
                        steals keyboard focus.
                    -->
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedBackground}" />
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedForeground}" />
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.InactiveSelectionHighlightBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedBackground}" />
                    <SolidColorBrush x:Key="{x:Static sys:SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedForeground}" />
                </TreeView.Resources>
                <TreeView.ContextMenu>
                    <ContextMenu x:Name="TreeContextMenu" />
                </TreeView.ContextMenu>
            </TreeView>

            <!-- Skills panel: a flat list of personal skills (~/.claude/skills/*/SKILL.md), populated
                 in code-behind by MainWindow.EnsureSkillsLoaded. Mutually exclusive with Tree via
                 Visibility, same convention as the canvas's own children below. -->
            <ListBox x:Name="SkillsList" Background="{DynamicResource Theme.Brush.WindowBackground}" BorderThickness="0"
                     Visibility="Collapsed"
                     SelectionChanged="OnSkillsListSelectionChanged"
                     MouseRightButtonDown="OnSkillsListMouseRightButtonDown"
                     ContextMenuOpening="OnSkillsListContextMenuOpening">
                <ListBox.ContextMenu>
                    <ContextMenu x:Name="SkillsContextMenu" />
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4" ToolTip="{Binding Info.FilePath}">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" />
                            <!-- Description is left plain (no visibility converter for the null/empty
                                 case) - an empty TextBlock with no MinHeight collapses to zero height
                                 visually, so there's no blank gap worth the extra converter class. -->
                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Theme.Brush.SecondaryForeground}" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{DynamicResource Theme.Brush.WindowBackground}" ResizeBehavior="PreviousAndNext" />

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--
                Tab strip: one tab per session opened from the Tree (see MainWindow.OpenTab),
                independent of which tree node happens to be selected - selecting a Project node no
                longer disturbs whichever tab is active (see MainWindow.OnTreeSelectedItemChanged).
                Collapsed entirely while the Skills rail section is active - see SetRailSection.
            -->
            <Border x:Name="TabStripHost" Grid.Row="0" Background="#181818" BorderBrush="#2D2D30" BorderThickness="0,0,0,1">
                <ListBox x:Name="TabStrip" Background="Transparent" BorderThickness="0"
                         ItemTemplate="{StaticResource SessionTabItemTemplate}"
                         ItemContainerStyle="{StaticResource SessionTabItemContainerStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionChanged="OnTabStripSelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Border>

            <Grid Grid.Row="1">
                <!--
                    Shown whenever there's no active tab (nothing ever opened, or the active tab
                    was just closed) and no skill is selected either. Always present, never
                    removed - only Visibility toggles, same rule as the session panes and
                    SkillDetail below.
                -->
                <TextBlock x:Name="PlaceholderText" Text="Select or launch a session" Foreground="{DynamicResource Theme.Brush.SecondaryForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <!-- Shown instead of launching when the active tab's session fails validation. -->
                <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Theme.Brush.Error}" TextWrapping="Wrap" MaxWidth="500"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

                <!--
                    Every running session's Pane.View is added here exactly once, permanently, for
                    that host's entire lifetime. Tab switching only ever toggles Visibility - never
                    swap Content/Children membership for a live view. See the comment in
                    MainWindow.LaunchSession for why.
                -->
                <Grid x:Name="SessionViewHost" />

                <!-- Rendered/edited SKILL.md for the currently selected skill - see Skills\SkillDetailView. -->
                <skills:SkillDetailView x:Name="SkillDetail" Visibility="Collapsed" />

                <!-- App preferences - see Settings\SettingsView. -->
                <settings:SettingsView x:Name="SettingsView" Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
