<Window x:Class="MultiClod.App.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="Rename Session" Height="140" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#1E1E1E">
    <!-- Same dark-theme resource block as ImportSessionWindow.xaml/AddSessionDialog.xaml - not
         shared via a merged dictionary since each window's sizing/padding differs slightly and
         there are only three call sites. -->
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="#3A96DD" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="#284861" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}" Color="White" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>
    <Grid Background="#1E1E1E" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="NameBox" Grid.Row="0" VerticalAlignment="Center" />

        <TextBlock x:Name="ErrorText" Grid.Row="1" Foreground="OrangeRed" TextWrapping="Wrap"
                   Margin="0,4,0,0" Visibility="Collapsed" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="70" IsDefault="True" Click="OnOkClick" Margin="0,0,6,0" />
            <Button Content="Cancel" Width="70" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
