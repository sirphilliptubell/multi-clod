<Window x:Class="MultiClod.App.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Session" Height="140" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="NameBox" Grid.Row="0" VerticalAlignment="Center" />

        <TextBlock x:Name="ErrorText" Grid.Row="1" Foreground="Red" TextWrapping="Wrap"
                   Margin="0,4,0,0" Visibility="Collapsed" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="70" IsDefault="True" Click="OnOkClick" Margin="0,0,6,0" />
            <Button Content="Cancel" Width="70" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
