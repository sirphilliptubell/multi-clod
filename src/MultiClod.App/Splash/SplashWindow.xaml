<Window x:Class="MultiClod.App.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi-Clod"
        Width="260" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Border Background="Black" CornerRadius="8" Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image x:Name="SpinnerIcon" Source="/Assets/app.png" Width="72" Height="72"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" Angle="0" />
                </Image.RenderTransform>
            </Image>
            <TextBlock x:Name="StatusText" Text="Starting..." Foreground="White" Margin="0,16,0,0"
                       HorizontalAlignment="Center" FontSize="13" />
        </StackPanel>
    </Border>
</Window>
