<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Light theme - white/near-white surfaces with dark text. Accent/status colors (Accent,
        AccentSecondary, AccentCoral, Error) stay identical to Dark.xaml so rail icons and the
        selection accent read the same across all three themes. See Dark.xaml for the full key list
        this must mirror.
    -->

    <Color x:Key="Theme.Color.WindowBackground">#FFFFFF</Color>
    <Color x:Key="Theme.Color.RailBackground">#F3F3F3</Color>
    <Color x:Key="Theme.Color.RailTileBackground">#E4E4E4</Color>
    <Color x:Key="Theme.Color.ControlBackground">#FFFFFF</Color>
    <Color x:Key="Theme.Color.SurfaceAlt">#F5F5F5</Color>
    <Color x:Key="Theme.Color.Border">#C9C9C9</Color>
    <Color x:Key="Theme.Color.PrimaryForeground">#1E1E1E</Color>
    <Color x:Key="Theme.Color.SecondaryForeground">#5F5F5F</Color>
    <Color x:Key="Theme.Color.Accent">#3A96DD</Color>
    <Color x:Key="Theme.Color.AccentSecondary">#3AA0E2</Color>
    <Color x:Key="Theme.Color.AccentCoral">#E2785A</Color>
    <Color x:Key="Theme.Color.SelectionUnfocusedBackground">#D6E8FA</Color>
    <Color x:Key="Theme.Color.SelectionUnfocusedForeground">#1E1E1E</Color>
    <Color x:Key="Theme.Color.ToggleTrackOff">#B5B5B5</Color>
    <Color x:Key="Theme.Color.Error">#FF4500</Color>
    <Color x:Key="Theme.Color.MarkdownForeground">#1E1E1E</Color>
    <!-- Darker than Dark/DarkLowContrast's gold (#D4AF37) - that value reads poorly against a white
         background, so Light uses a deeper "goldenrod" tone with better contrast instead. -->
    <Color x:Key="Theme.Color.Cost">#8B6508</Color>

    <SolidColorBrush x:Key="Theme.Brush.WindowBackground" Color="{StaticResource Theme.Color.WindowBackground}" />
    <SolidColorBrush x:Key="Theme.Brush.RailBackground" Color="{StaticResource Theme.Color.RailBackground}" />
    <SolidColorBrush x:Key="Theme.Brush.RailTileBackground" Color="{StaticResource Theme.Color.RailTileBackground}" />
    <SolidColorBrush x:Key="Theme.Brush.ControlBackground" Color="{StaticResource Theme.Color.ControlBackground}" />
    <SolidColorBrush x:Key="Theme.Brush.SurfaceAlt" Color="{StaticResource Theme.Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Theme.Brush.Border" Color="{StaticResource Theme.Color.Border}" />
    <SolidColorBrush x:Key="Theme.Brush.PrimaryForeground" Color="{StaticResource Theme.Color.PrimaryForeground}" />
    <SolidColorBrush x:Key="Theme.Brush.SecondaryForeground" Color="{StaticResource Theme.Color.SecondaryForeground}" />
    <SolidColorBrush x:Key="Theme.Brush.Accent" Color="{StaticResource Theme.Color.Accent}" />
    <SolidColorBrush x:Key="Theme.Brush.AccentSecondary" Color="{StaticResource Theme.Color.AccentSecondary}" />
    <SolidColorBrush x:Key="Theme.Brush.AccentCoral" Color="{StaticResource Theme.Color.AccentCoral}" />
    <SolidColorBrush x:Key="Theme.Brush.SelectionUnfocusedBackground" Color="{StaticResource Theme.Color.SelectionUnfocusedBackground}" />
    <SolidColorBrush x:Key="Theme.Brush.SelectionUnfocusedForeground" Color="{StaticResource Theme.Color.SelectionUnfocusedForeground}" />
    <SolidColorBrush x:Key="Theme.Brush.ToggleTrackOff" Color="{StaticResource Theme.Color.ToggleTrackOff}" />
    <SolidColorBrush x:Key="Theme.Brush.Error" Color="{StaticResource Theme.Color.Error}" />
    <SolidColorBrush x:Key="Theme.Brush.MarkdownForeground" Color="{StaticResource Theme.Color.MarkdownForeground}" />
    <SolidColorBrush x:Key="Theme.Brush.Cost" Color="{StaticResource Theme.Color.Cost}" />

</ResourceDictionary>
