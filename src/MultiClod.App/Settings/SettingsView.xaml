<UserControl x:Class="MultiClod.App.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Shared with Skills\SkillDetailView's Edit toggle - not duplicated here. -->
                <ResourceDictionary Source="/MultiClod.App;component/Skills/ToggleSwitchStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CaretBrush" Value="White" />
                <Setter Property="BorderBrush" Value="#3F3F3F" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="Background" Value="#2A2A2A" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#3F3F3F" />
                <Setter Property="Padding" Value="10,6" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="#1E1E1E">
        <StackPanel Margin="24" MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

            <TextBlock Text="General" Foreground="Gray" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <ToggleButton x:Name="ShiftEnterToggle" Style="{StaticResource ToggleSwitchStyle}"
                              Click="OnShiftEnterToggleClick" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Use Shift+Enter for newlines" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="When on, Shift+Enter inserts a newline in a session instead of Ctrl+Enter."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="52,0,0,0" />

            <TextBlock Text="Sessions" Foreground="Gray" FontSize="12" FontWeight="Bold" Margin="0,20,0,8" />

            <TextBlock Text="Default root folder" Foreground="White" Margin="0,0,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DefaultRootFolderBox" Grid.Column="0" IsReadOnly="True" />
                <Button Grid.Column="1" Content="Browse..." Click="OnBrowseDefaultRootFolderClick" Margin="8,0,0,0" />
            </Grid>
            <TextBlock Text="New sessions default to this folder (see Add Session's form)."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,16" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <ToggleButton x:Name="WorktreeToggle" Style="{StaticResource ToggleSwitchStyle}"
                              Click="OnWorktreeToggleClick" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Start new sessions with a git worktree" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Pre-checks &quot;Create a git worktree&quot; in the Add Session form - still editable per session."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="52,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
