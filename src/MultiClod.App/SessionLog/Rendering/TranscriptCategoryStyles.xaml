<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:rendering="clr-namespace:MultiClod.App.SessionLog.Rendering">

    <rendering:CategoryToGlyphConverter x:Key="CategoryToGlyphConverter" />
    <rendering:CategoryToBrushConverter x:Key="CategoryToBrushConverter" />

    <SolidColorBrush x:Key="ToolCallErrorBrush" Color="#C0392B" />
    <FontFamily x:Key="TranscriptIconFontFamily">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <Style x:Key="TranscriptRowBorderStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Background" Value="#1E1E1E" />
    </Style>

    <!-- Content is set inline per DataTemplate (a Segoe Fluent Icons "Copy" glyph), not here - a
         Style Setter can't hold a shared UIElement value across multiple Button instances.
         Positioning (HorizontalAlignment/VerticalAlignment) is also set inline per template, on an
         outer Grid that overlays the button on top of the Expander rather than inside its Header -
         Expander's built-in header presenter doesn't stretch to fill its full width, so a "*"
         column there has nothing to actually push the button into. -->
    <Style x:Key="TranscriptCopyButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="#2A2A2A" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#3F3F3F" />
        <Setter Property="ToolTip" Value="Copy entry JSON" />
        <Setter Property="Command" Value="{x:Static rendering:SessionLogCommands.CopyEntryJson}" />
        <Setter Property="CommandParameter" Value="{Binding}" />
    </Style>

    <Style x:Key="TranscriptRowHeaderIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TranscriptIconFontFamily}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Text" Value="{Binding Category, Converter={StaticResource CategoryToGlyphConverter}}" />
        <Setter Property="Foreground" Value="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}" />
    </Style>

    <!-- TextBlock has no built-in text selection, so expanded body/JSON text is rendered in a
         read-only TextBox styled to look like a TextBlock instead - lets the user select and
         Ctrl+C entry text, which a plain TextBlock can't do. -->
    <Style x:Key="TranscriptSelectableTextStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsReadOnlyCaretVisible" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Cursor" Value="IBeam" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SelectionBrush" Value="#3A96DD" />
    </Style>

    <Style x:Key="TranscriptAdditionalPropertiesTextStyle" TargetType="TextBox" BasedOn="{StaticResource TranscriptSelectableTextStyle}">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="Foreground" Value="#AAAAAA" />
        <Setter Property="Background" Value="#141414" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <!-- User / Assistant text and image-block rows - only Category differs, so both share this
         one template; the icon/accent color follow Category automatically via the converters. -->
    <DataTemplate DataType="{x:Type rendering:MessageTextRowViewModel}">
        <Border Style="{StaticResource TranscriptRowBorderStyle}" BorderBrush="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock Style="{StaticResource TranscriptRowHeaderIconStyle}" />
                            <TextBlock Text="{Binding SummaryText}" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="24,6,4,4">
                        <TextBox Style="{StaticResource TranscriptSelectableTextStyle}" Text="{Binding ExpandedBodyText, Mode=OneWay}" Foreground="#DDDDDD" />
                        <Expander Header="Additional Properties" IsExpanded="{Binding IsAdditionalPropertiesExpanded, Mode=TwoWay}" Margin="0,8,0,0" Foreground="Gray">
                            <TextBox Style="{StaticResource TranscriptAdditionalPropertiesTextStyle}" Text="{Binding AdditionalPropertiesJson, Mode=OneWay}" />
                        </Expander>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource TranscriptCopyButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,4,0">
                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource TranscriptIconFontFamily}" FontSize="12" />
                </Button>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Thinking rows - de-emphasized (muted/italic) body, distinct from the assistant's visible
         text even though both come from the same assistant entry. -->
    <DataTemplate DataType="{x:Type rendering:ThinkingRowViewModel}">
        <Border Style="{StaticResource TranscriptRowBorderStyle}" BorderBrush="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock Style="{StaticResource TranscriptRowHeaderIconStyle}" />
                            <TextBlock Text="{Binding SummaryText}" Foreground="#B9AEDD" FontStyle="Italic" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="24,6,4,4">
                        <TextBox Style="{StaticResource TranscriptSelectableTextStyle}" Text="{Binding ExpandedBodyText, Mode=OneWay}" FontStyle="Italic" Foreground="#B9AEDD" />
                        <Expander Header="Additional Properties" IsExpanded="{Binding IsAdditionalPropertiesExpanded, Mode=TwoWay}" Margin="0,8,0,0" Foreground="Gray">
                            <TextBox Style="{StaticResource TranscriptAdditionalPropertiesTextStyle}" Text="{Binding AdditionalPropertiesJson, Mode=OneWay}" />
                        </Expander>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource TranscriptCopyButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,4,0">
                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource TranscriptIconFontFamily}" FontSize="12" />
                </Button>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Tool call rows - accent/glyph color switches to ToolCallErrorBrush once resolved with a
         failure, via the DataTrigger on IsError below (Category alone can't express that). -->
    <DataTemplate DataType="{x:Type rendering:ToolCallRowViewModel}">
        <Border Style="{StaticResource TranscriptRowBorderStyle}" x:Name="ToolCallBorder"
                BorderBrush="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock x:Name="ToolCallIcon" Style="{StaticResource TranscriptRowHeaderIconStyle}" />
                            <TextBlock x:Name="ToolCallSummary" Text="{Binding SummaryText}" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="24,6,4,4">
                        <TextBox Style="{StaticResource TranscriptSelectableTextStyle}" Text="{Binding ExpandedBodyText, Mode=OneWay}" FontFamily="Consolas" Foreground="#DDDDDD" />
                        <Expander Header="Additional Properties" IsExpanded="{Binding IsAdditionalPropertiesExpanded, Mode=TwoWay}" Margin="0,8,0,0" Foreground="Gray">
                            <TextBox Style="{StaticResource TranscriptAdditionalPropertiesTextStyle}" Text="{Binding AdditionalPropertiesJson, Mode=OneWay}" />
                        </Expander>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource TranscriptCopyButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,4,0">
                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource TranscriptIconFontFamily}" FontSize="12" />
                </Button>
            </Grid>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsError}" Value="True">
                <Setter TargetName="ToolCallBorder" Property="BorderBrush" Value="{StaticResource ToolCallErrorBrush}" />
                <Setter TargetName="ToolCallIcon" Property="Foreground" Value="{StaticResource ToolCallErrorBrush}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- System/meta rows - hidden by default behind TranscriptViewerControl's "Show all events"
         toggle; low-contrast so they read as background noise even when shown. -->
    <DataTemplate DataType="{x:Type rendering:SystemMetaRowViewModel}">
        <Border Style="{StaticResource TranscriptRowBorderStyle}" BorderBrush="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}" Opacity="0.75">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock Style="{StaticResource TranscriptRowHeaderIconStyle}" />
                            <TextBlock Text="{Binding SummaryText}" Foreground="#AAAAAA" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="24,6,4,4">
                        <Expander Header="Additional Properties" IsExpanded="{Binding IsAdditionalPropertiesExpanded, Mode=TwoWay}" Foreground="Gray">
                            <TextBox Style="{StaticResource TranscriptAdditionalPropertiesTextStyle}" Text="{Binding AdditionalPropertiesJson, Mode=OneWay}" />
                        </Expander>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource TranscriptCopyButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,4,0">
                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource TranscriptIconFontFamily}" FontSize="12" />
                </Button>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Unrecognized rows - reserved for actual parse failures only (see UnrecognizedRowViewModel)
         - amber/warning treatment so a malformed line is easy to spot rather than blending in. -->
    <DataTemplate DataType="{x:Type rendering:UnrecognizedRowViewModel}">
        <Border Style="{StaticResource TranscriptRowBorderStyle}" BorderBrush="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}" BorderThickness="2">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                            <TextBlock Style="{StaticResource TranscriptRowHeaderIconStyle}" />
                            <TextBlock Text="{Binding SummaryText}" Foreground="#E8D08A" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="24,6,4,4">
                        <TextBox Style="{StaticResource TranscriptSelectableTextStyle}" Text="{Binding ExpandedBodyText, Mode=OneWay}" FontFamily="Consolas" Foreground="#DDDDDD" />
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource TranscriptCopyButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,4,0">
                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource TranscriptIconFontFamily}" FontSize="12" />
                </Button>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
