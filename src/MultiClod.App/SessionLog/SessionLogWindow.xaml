<Window x:Class="MultiClod.App.SessionLog.SessionLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        xmlns:sessionLog="clr-namespace:MultiClod.App.SessionLog"
        Title="Session Log" Height="900" Width="1400"
        MaxHeight="{x:Static sys:SystemParameters.PrimaryScreenHeight}"
        MaxWidth="{x:Static sys:SystemParameters.PrimaryScreenWidth}">
    <!-- Same SystemColors overrides as MainWindow.xaml/ImportSessionWindow.xaml, so selection
         highlighting in the subagents ListBox matches the rest of the app's dark theme. -->
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="#3A96DD" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="#284861" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}" Color="White" />
    </Window.Resources>
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="#181818">
            <TextBlock x:Name="MainSessionHeader" DockPanel.Dock="Top" Text="Main Session"
                       Foreground="White" FontWeight="Bold" Padding="10,10,10,6" Cursor="Hand"
                       MouseLeftButtonUp="OnMainSessionSelected" />
            <Separator DockPanel.Dock="Top" Margin="8,0,8,4" />
            <TextBlock DockPanel.Dock="Top" Text="SUBAGENTS" Foreground="Gray" Padding="10,4" FontSize="11" />
            <ListBox x:Name="SubagentsListBox" Background="#181818" BorderThickness="0"
                     SelectionChanged="OnSubagentSelected">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type sessionLog:SessionLogSourceViewModel}">
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" Padding="4,2" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <sessionLog:TranscriptViewerControl x:Name="Viewer" Grid.Column="1" />
    </Grid>
</Window>
