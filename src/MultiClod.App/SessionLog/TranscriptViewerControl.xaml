<UserControl x:Class="MultiClod.App.SessionLog.TranscriptViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox x:Name="ShowAllEventsCheckBox" Grid.Row="0" Content="Show all events"
                  Foreground="White" Margin="8,6" Checked="OnShowAllEventsChanged" Unchecked="OnShowAllEventsChanged" />

        <Grid Grid.Row="1">
            <TextBlock x:Name="WaitingText" Text="Waiting for session to start..." Foreground="Gray"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

            <ScrollViewer x:Name="RowsScrollViewer" VerticalScrollBarVisibility="Auto" ScrollChanged="OnRowsScrollChanged">
                <ItemsControl x:Name="RowsItemsControl" Margin="8" />
            </ScrollViewer>
        </Grid>

        <TextBlock x:Name="AccessProblemText" Grid.Row="2" Foreground="#D9A93A" Margin="8,4"
                   Text="Lost access to the transcript file - retrying..." Visibility="Collapsed" />
    </Grid>
</UserControl>
