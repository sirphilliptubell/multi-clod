<Window x:Class="MultiClod.App.ImportSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="Import Session" Height="960" Width="1640"
        MaxHeight="{x:Static sys:SystemParameters.PrimaryScreenHeight}"
        MaxWidth="{x:Static sys:SystemParameters.PrimaryScreenWidth}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.Brush.WindowBackground}">
    <!-- Same SystemColors overrides as MainWindow.xaml's TreeView.Resources, so the DataGrid's
         selection highlight matches the rest of the app's theme instead of the stock
         light-gray ListBox/DataGrid selection colors. Control.Foreground inherits down the tree,
         so overriding ControlTextBrushKey here also affects TextBox/Button - both get their own
         explicit Background/Foreground/BorderBrush below rather than relying on inherited/default
         values, since a plain TextBox's default Background stays white regardless of this. -->
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="{DynamicResource Theme.Color.Accent}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedBackground}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedForeground}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.InactiveSelectionHighlightBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedBackground}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedForeground}" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource Theme.Brush.WindowBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" VerticalAlignment="Center" KeyDown="OnSearchBoxKeyDown" />
            <Button x:Name="SearchButton" Grid.Column="1" Content="Search" Width="90" Margin="10,0,0,0" Click="OnSearchClick" />
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="1" Foreground="{DynamicResource Theme.Brush.SecondaryForeground}" Margin="0,0,0,10" />

        <DataGrid x:Name="ResultsGrid" Grid.Row="2"
                  Background="{DynamicResource Theme.Brush.WindowBackground}" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" BorderThickness="1" BorderBrush="{DynamicResource Theme.Brush.Border}"
                  RowBackground="{DynamicResource Theme.Brush.WindowBackground}" AlternatingRowBackground="{DynamicResource Theme.Brush.SurfaceAlt}" RowHeight="28"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="None"
                  SelectionChanged="OnResultsSelectionChanged" MouseDoubleClick="OnResultsDoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
                    <Setter Property="Padding" Value="8,6" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,0" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Directory" Binding="{Binding ProjectDirectoryName}" Width="2*" />
                <DataGridTextColumn Header="File" Binding="{Binding MatchedFileDisplayPath}" Width="2*" />
                <DataGridTextColumn Header="Summary" Binding="{Binding SummaryOrSessionId}" Width="3*" />
                <DataGridTextColumn Header="Session Id" Binding="{Binding ParentSessionId}" Width="2*" />
                <DataGridTextColumn x:Name="ModifiedColumn" Header="Modified" Binding="{Binding LastModified, StringFormat='yyyy-MM-dd HH:mm'}" Width="1.3*" SortDirection="Descending" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="ImportButton" Content="Import" Width="90" IsEnabled="False" Margin="0,0,10,0" Click="OnImportClick" />
            <Button Content="Cancel" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
