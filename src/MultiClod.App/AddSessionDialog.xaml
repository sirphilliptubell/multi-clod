<Window x:Class="MultiClod.App.AddSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="Add Session" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Theme.Brush.WindowBackground}">
    <!-- Same SystemColors/TextBox/Button theme overrides as ImportSessionWindow.xaml - not
         shared via a merged dictionary since each window's font sizing/padding differs slightly
         and there are only two call sites. -->
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}" Color="{DynamicResource Theme.Color.Accent}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedBackground}" />
        <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}" Color="{DynamicResource Theme.Color.SelectionUnfocusedForeground}" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <!-- Full retemplate, not just Background/Foreground setters - WPF's default ComboBox
             chrome (ToggleButton + selection ContentPresenter) draws its closed-box text via
             internal SystemColors-driven brushes that a plain style setter doesn't reach, which is
             what made the branch select unreadable (dark-on-dark) before this. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{DynamicResource Theme.Brush.ControlBackground}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z" Fill="{DynamicResource Theme.Brush.PrimaryForeground}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <!-- Only rendered when IsEditable (see the trigger below) - required for
                                 typing/searching to work at all: WPF's editable ComboBox looks for a
                                 part named exactly PART_EditableTextBox in the template and silently
                                 falls back to non-editable behavior if it's missing. Right margin
                                 clears the 24px arrow column so typed text can't render under it. -->
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     Margin="8,6,28,6" Padding="0"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource Theme.Brush.ControlBackground}" BorderBrush="{DynamicResource Theme.Brush.Border}" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.PrimaryForeground}" />
        </Style>
    </Window.Resources>

    <StackPanel Background="{DynamicResource Theme.Brush.WindowBackground}" Margin="16">
        <TextBlock Text="Session name" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" TextChanged="OnNameTextChanged" />

        <TextBlock Text="Folder" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" Margin="0,14,0,4" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderBox" Grid.Column="0" IsReadOnly="True" />
            <Button Grid.Column="1" Content="Browse..." Click="OnBrowseFolderClick" Margin="8,0,0,0" />
        </Grid>

        <!-- Only shown once the chosen Folder is actually detected as a git repository - see
             UpdateWorktreeSectionVisibility. Collapsed (not just disabled) rather than shown
             greyed-out, since "no git repo here" makes the whole option inapplicable, not merely
             unavailable right now. -->
        <StackPanel x:Name="WorktreeSection" Visibility="Collapsed">
            <CheckBox x:Name="WorktreeCheckBox" Content="Create a git worktree for this session"
                      Margin="0,18,0,0" Checked="OnWorktreeCheckedChanged" Unchecked="OnWorktreeCheckedChanged" />

            <!-- Hidden rather than just disabled while WorktreeCheckBox is unchecked - see
                 OnWorktreeCheckedChanged. -->
            <StackPanel x:Name="WorktreeControls" Visibility="Collapsed">
                <TextBlock Text="Worktree name (new branch)" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" Margin="0,14,0,4" />
                <TextBox x:Name="WorktreeNameBox" />

                <TextBlock Text="Branch to create it from" Foreground="{DynamicResource Theme.Brush.PrimaryForeground}" Margin="0,14,0,4" />
                <!-- IsEditable + a custom filter (OnBranchComboTextChanged/FilterBranch in the code-behind)
                     make this searchable: WPF's built-in IsTextSearchEnabled only jumps to the first
                     matching item rather than narrowing the list, so it's turned off in favor of that. -->
                <ComboBox x:Name="BranchCombo" IsEditable="True" IsTextSearchEnabled="False"
                          TextBoxBase.TextChanged="OnBranchComboTextChanged" />
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Theme.Brush.Error}" TextWrapping="Wrap" Margin="0,14,0,0" Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Add" Width="80" IsDefault="True" Click="OnAddClick" Margin="0,0,8,0" />
            <Button Content="Cancel" Width="80" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
